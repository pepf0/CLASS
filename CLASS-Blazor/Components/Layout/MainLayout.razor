@inherits LayoutComponentBase
@inject IJSRuntime JS

<nav class="navbar navbar-expand-lg custom-navbar fixed-top">
    <div class="container">
        <a class="navbar-brand" href="/">
            <img src="/images/logo_text.png" alt="CLASS Logo" />
        </a>

        <ul class="navbar-nav ms-auto desktop-nav">
            <li class="nav-item">
                <NavLink class="nav-link custom-link" href="/" Match="NavLinkMatch.All">Home</NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link custom-link" href="/nachhilfe">Nachhilfe</NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link custom-link" href="/dashboard">Dashboard</NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link custom-link" href="/profil">Profil</NavLink>
            </li>
        </ul>

        <button class="theme-toggle"
                type="button"
                @onclick="ToggleThemeAsync"
                aria-label="Darkmode umschalten"
                aria-pressed="@IsDarkMode">
            @if (IsDarkMode)
            {
                <svg viewBox="0 0 24 24" class="theme-icon" aria-hidden="true">
                    <circle cx="12" cy="12" r="4.25"></circle>
                    <line x1="12" y1="1.75" x2="12" y2="4.25"></line>
                    <line x1="12" y1="19.75" x2="12" y2="22.25"></line>
                    <line x1="1.75" y1="12" x2="4.25" y2="12"></line>
                    <line x1="19.75" y1="12" x2="22.25" y2="12"></line>
                    <line x1="4.75" y1="4.75" x2="6.5" y2="6.5"></line>
                    <line x1="17.5" y1="17.5" x2="19.25" y2="19.25"></line>
                    <line x1="17.5" y1="6.5" x2="19.25" y2="4.75"></line>
                    <line x1="4.75" y1="19.25" x2="6.5" y2="17.5"></line>
                </svg>
            }
            else
            {
                <img src="/images/icons/moon-icon.png" alt="" class="theme-icon theme-icon-moon" aria-hidden="true" />
            }
        </button>

        <button class="mobile-menu-btn"
                type="button"
                @onclick="ToggleSidebar"
                aria-label="Menü öffnen"
                aria-expanded="@IsSidebarOpen">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</nav>

<div class="mobile-overlay @(IsSidebarOpen ? "show" : string.Empty)" @onclick="CloseSidebar"></div>

<aside class="mobile-sidebar @(IsSidebarOpen ? "open" : string.Empty)">
    <nav class="mobile-sidebar-nav">
        <button class="theme-toggle mobile-theme-toggle"
                type="button"
                @onclick="ToggleThemeAsync"
                aria-label="Darkmode umschalten"
                aria-pressed="@IsDarkMode">
            @if (IsDarkMode)
            {
                <svg viewBox="0 0 24 24" class="theme-icon" aria-hidden="true">
                    <circle cx="12" cy="12" r="4.25"></circle>
                    <line x1="12" y1="1.75" x2="12" y2="4.25"></line>
                    <line x1="12" y1="19.75" x2="12" y2="22.25"></line>
                    <line x1="1.75" y1="12" x2="4.25" y2="12"></line>
                    <line x1="19.75" y1="12" x2="22.25" y2="12"></line>
                    <line x1="4.75" y1="4.75" x2="6.5" y2="6.5"></line>
                    <line x1="17.5" y1="17.5" x2="19.25" y2="19.25"></line>
                    <line x1="17.5" y1="6.5" x2="19.25" y2="4.75"></line>
                    <line x1="4.75" y1="19.25" x2="6.5" y2="17.5"></line>
                </svg>
            }
            else
            {
                <img src="/images/icons/moon-icon.png" alt="" class="theme-icon theme-icon-moon" aria-hidden="true" />
            }
        </button>
        <NavLink class="mobile-link" href="/" Match="NavLinkMatch.All" @onclick="CloseSidebar">Home</NavLink>
        <NavLink class="mobile-link" href="/nachhilfe" @onclick="CloseSidebar">Nachhilfe</NavLink>
        <NavLink class="mobile-link" href="/dashboard" @onclick="CloseSidebar">Dashboard</NavLink>
        <NavLink class="mobile-link" href="/profil" @onclick="CloseSidebar">Profil</NavLink>
    </nav>
</aside>

<div class="page-content">
    @Body
</div>

@code {
    private bool IsSidebarOpen;
    private bool IsDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        IsDarkMode = await JS.InvokeAsync<bool>("themeManager.isDarkMode");
        StateHasChanged();
    }

    private void ToggleSidebar()
    {
        IsSidebarOpen = !IsSidebarOpen;
    }

    private void CloseSidebar()
    {
        IsSidebarOpen = false;
    }

    private async Task ToggleThemeAsync()
    {
        IsDarkMode = await JS.InvokeAsync<bool>("themeManager.toggleTheme");
    }
}
