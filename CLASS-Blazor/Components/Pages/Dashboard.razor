@page "/dashboard"
@implements IDisposable
@inject DashboardDataService DashboardData
@inject NavigationManager NavigationManager
@inject AuthSessionStorageService AuthSessionStorage
@inject TutorDirectoryService TutorDirectoryService
@inject UserSessionService UserSessionService
@inject TutorRequestService TutorRequestService
@inject TutorRequestStatusOverlayService RequestStatusOverlay
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

<section class="dashboard-page page-with-footer-space">
    @if (IsLoading)
    {
        <div class="empty-state">
            <h3>Dashboard wird geladen</h3>
            <p>Kennzahlen, Anfragen und Aktivit&auml;ten werden vorbereitet.</p>
        </div>
    }
    else if (Snapshot is not null)
    {
        <header class="dashboard-header">
            <div>
                <p class="dashboard-kicker">Tutor Dashboard</p>
                <h1>&Uuml;berblick f&uuml;r deine Nachhilfe</h1>
                <p>Anfragen, Umsatz und gebuchte Stunden auf einen Blick.</p>
            </div>

            <div class="dashboard-header-actions">
                <button type="button" class="dashboard-quick-action" @onclick="GoToOffer">
                    <span>@(Snapshot.HasOffer ? "Angebot bearbeiten" : "Angebot erstellen")</span>
                    <small>@(Snapshot.HasOffer ? "Profil aktualisieren" : "Profil vervollst&auml;ndigen")</small>
                </button>

                @if (Snapshot.HasOffer)
                {
                    <button type="button"
                            class="btn-danger-custom dashboard-delete-offer-button"
                            @onclick="DeleteTutorOffer">
                        @(IsDeleteConfirmationVisible ? "Wirklich löschen?" : "Angebot löschen")
                    </button>
                }
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(DeleteOfferMessage))
        {
            <p class="dashboard-offer-message">@DeleteOfferMessage</p>
        }

        <section class="dashboard-summary-grid" aria-label="Dashboard Zusammenfassung">
            <div class="dashboard-summary-stack">
                <a class="dashboard-summary-card dashboard-summary-card-requests" href="#dashboard-requests">
                    <span class="dashboard-summary-label">Anfragen</span>
                    <strong class="dashboard-summary-value">@OpenRequests.Count</strong>
                    <span class="dashboard-summary-meta">@GetOpenRequestsLabel()</span>
                </a>

                <article class="dashboard-summary-card dashboard-summary-card-completed">
                    <span class="dashboard-summary-label">Abgeschlossen</span>
                    <strong class="dashboard-summary-value">@Snapshot.CompletedHours h</strong>
                    <span class="dashboard-summary-meta">gegebene Nachhilfestunden</span>
                </article>

                <article class="dashboard-summary-card dashboard-summary-card-revenue">
                    <span class="dashboard-summary-label">Umsatz</span>
                    <strong class="dashboard-summary-value">@Snapshot.CurrentMonthRevenue.ToString("0") EUR</strong>
                    <span class="dashboard-summary-meta">dieser Monat</span>
                </article>
            </div>

            <article class="dashboard-subject-panel">
                <div class="dashboard-subject-heading">
                    <div>
                        <p class="dashboard-section-kicker">Fachverteilung</p>
                        <h2>Gegebene Stunden</h2>
                    </div>
                </div>

                <div class="dashboard-subject-content">
                    <div class="dashboard-subject-donut-wrap">
                        <svg class="dashboard-subject-donut"
                             viewBox="0 0 120 120"
                             role="img"
                             aria-label="@SubjectDonutAriaLabel">
                            <defs>
                                <mask id="dashboard-subject-donut-reveal" maskUnits="userSpaceOnUse">
                                    <circle class="dashboard-subject-donut-mask"
                                            cx="60"
                                            cy="60"
                                            r="46"
                                            pathLength="100"></circle>
                                </mask>
                            </defs>
                            <circle class="dashboard-subject-donut-base" cx="60" cy="60" r="46"></circle>
                            <g class="dashboard-subject-donut-segments" mask="url(#dashboard-subject-donut-reveal)">
                                @foreach (var segment in OrderedSubjectSegments)
                                {
                                    <circle class="dashboard-subject-donut-segment"
                                            cx="60"
                                            cy="60"
                                            r="46"
                                            pathLength="100"
                                            stroke="@segment.Color"
                                            stroke-dasharray="@segment.DashArray"
                                            stroke-dashoffset="@segment.DashOffset"
                                            aria-hidden="true"></circle>
                                }
                            </g>
                        </svg>
                        <span class="dashboard-subject-total">@TotalSubjectHours.ToString("0.#") h</span>
                    </div>

                    <div class="dashboard-subject-legend">
                        @{
                            var subjectIndex = 0;
                        }
                        @foreach (var subject in Snapshot.SubjectHours)
                        {
                            <div class="dashboard-subject-legend-item" style="@GetSubjectLegendStyle(subjectIndex)" @key="subject.Subject">
                                <span class="dashboard-subject-color" style="background:@subject.Color"></span>
                                <span>@subject.Subject</span>
                                <strong>@subject.Hours.ToString("0.#") h</strong>
                            </div>
                            subjectIndex++;
                        }
                    </div>
                </div>
            </article>
        </section>

        <section class="dashboard-chart-grid" aria-label="Dashboard Diagramme">
            <DashboardChart Title="Einnahmen pro Monat"
                            Kicker="Umsatz"
                            Data="SelectedYearRevenue"
                            IsCurrency="true"
                            PeriodLabel="@SelectedRevenueYear.ToString()"
                            OnPreviousPeriod="ShowPreviousRevenueYear"
                            OnNextPeriod="ShowNextRevenueYear" />
        </section>

        <section class="dashboard-work-grid" aria-label="Anfragen und Aktivit&auml;ten">
            <DashboardRequestList Requests="OpenRequests"
                                  OnAccept="AcceptRequest"
                                  OnDecline="DeclineRequest"
                                  OnCancel="CancelRequest"
                                  OnMarkRead="MarkRequestRead" />
            <DashboardActivityFeed Activities="VisibleActivities" />
        </section>

        @if (!string.IsNullOrWhiteSpace(RequestActionMessage))
        {
            <p class="dashboard-request-message">@RequestActionMessage</p>
        }
    }
</section>

@code {
    private static readonly (string Title, string Detail, string Tone)[] FeedTemplates =
    {
        ("Neue Anfrage", "Neue Buchung eingegangen.", "info"),
        ("Stunde abgeschlossen", "Einheit wurde abgeschlossen.", "success"),
        ("Anfrage aktualisiert", "Status wurde aktualisiert.", "neutral")
    };

    private static readonly string[] MonthLabels =
    {
        "Jan",
        "Feb",
        "Mar",
        "Apr",
        "Mai",
        "Jun",
        "Jul",
        "Aug",
        "Sep",
        "Okt",
        "Nov",
        "Dez"
    };

    private static readonly Dictionary<int, decimal[]> RevenueByYear = new()
    {
        [2024] = new[] { 0m, 0m, 18m, 0m, 36m, 18m, 0m, 0m, 54m, 72m, 36m, 72m },
        [2025] = new[] { 54m, 72m, 90m, 72m, 0m, 34m, 18m, 0m, 72m, 90m, 54m, 108m },
        [2026] = new[] { 72m, 96m, 126m, 126m, 0m, 0m, 0m, 0m, 0m, 0m, 0m, 0m }
    };

    private const string ReadRequestStoragePrefix = "class-dashboard-read-request";

    private DashboardSnapshot? Snapshot { get; set; }

    private List<TutorRequest> OpenRequests { get; set; } = new();

    private List<DashboardActivity> Activities { get; set; } = new();

    private TutorOffer? CurrentTutorOffer { get; set; }

    private string DeleteOfferMessage { get; set; } = string.Empty;

    private string RequestActionMessage { get; set; } = string.Empty;

    private bool IsDeleteConfirmationVisible { get; set; }

    private CancellationTokenSource? FeedCancellation { get; set; }

    private bool IsLoading { get; set; } = true;

    private int FeedIndex { get; set; }

    private int SelectedRevenueYear { get; set; } = DateTime.Today.Year;

    private IReadOnlyList<DashboardChartPoint> SelectedYearRevenue
    {
        get
        {
            if (Snapshot is not null && !Snapshot.IsTestData)
            {
                return Snapshot.RevenueByMonth;
            }

            var values = RevenueByYear.TryGetValue(SelectedRevenueYear, out var yearValues)
                ? yearValues
                : new decimal[12];

            return MonthLabels
                .Select((month, index) => new DashboardChartPoint(month, values.ElementAtOrDefault(index)))
                .ToList();
        }
    }

    private IReadOnlyList<DashboardActivity> VisibleActivities => Activities.Take(5).ToList();

    private decimal TotalSubjectHours => Snapshot?.SubjectHours.Sum(subject => subject.Hours) ?? 0m;

    private string SubjectDonutAriaLabel =>
        Snapshot is null
            ? "Keine Fachstunden vorhanden"
            : $"Fachverteilung: {string.Join(", ", Snapshot.SubjectHours.Select(subject => $"{subject.Subject} {subject.Hours:0.#} Stunden"))}";

    private IReadOnlyList<SubjectDonutSegment> SubjectSegments
    {
        get
        {
            if (Snapshot is null || TotalSubjectHours <= 0)
            {
                return Array.Empty<SubjectDonutSegment>();
            }

            var offset = 0m;
            var segments = new List<SubjectDonutSegment>();
            var subjects = Snapshot.SubjectHours.Where(subject => subject.Hours > 0).ToList();

            for (var index = 0; index < subjects.Count; index++)
            {
                var subject = subjects[index];
                var isLastSegment = index == subjects.Count - 1;
                var share = isLastSegment
                    ? Math.Max(0m, 100m - offset + 0.35m)
                    : decimal.Round(subject.Hours / TotalSubjectHours * 100m, 2);

                segments.Add(new SubjectDonutSegment(
                    subject.Color,
                    $"{FormatPercent(share)} {FormatPercent(Math.Max(0m, 100m - share))}",
                    FormatPercent(-offset)));
                offset += share;
            }

            return segments;
        }
    }

    private IReadOnlyList<SubjectDonutSegment> OrderedSubjectSegments =>
        SubjectSegments.Count <= 1
            ? SubjectSegments
            : SubjectSegments.Skip(1).Append(SubjectSegments[0]).ToList();

    private static string FormatPercent(decimal value)
    {
        return value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string GetSubjectLegendStyle(int index)
    {
        return $"--legend-delay:{(0.28 + index * 0.08).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}s;";
    }

    private string GetOpenRequestsLabel()
    {
        return OpenRequests.Count == 1
            ? "braucht deine Aufmerksamkeit"
            : "brauchen deine Aufmerksamkeit";
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthSessionStorage.RestoreFromCookieAsync();
        Snapshot = await DashboardData.GetDashboardAsync();
        CurrentTutorOffer = await GetCurrentTutorOfferAsync();
        OpenRequests = Snapshot.OpenRequests.ToList();
        Activities = Snapshot.Activities.ToList();
        IsLoading = false;

        FeedCancellation = new CancellationTokenSource();

        if (Snapshot.IsTestData)
        {
            _ = RefreshFeedAsync(FeedCancellation.Token);
        }
        else
        {
            _ = RefreshDashboardAsync(FeedCancellation.Token);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Snapshot is null)
        {
            return;
        }

        OpenRequests = await FilterReadRequestsAsync(OpenRequests);
        StateHasChanged();
    }

    private async Task AcceptRequest(TutorRequest request)
    {
        await UpdateRequestStatusAsync(request, TutorRequestStatus.Accepted, "accepted");
    }

    private async Task DeclineRequest(TutorRequest request)
    {
        await UpdateRequestStatusAsync(request, TutorRequestStatus.Declined, "declined");
    }

    private async Task CancelRequest(TutorRequest request)
    {
        await UpdateRequestStatusAsync(request, TutorRequestStatus.Cancelled, "cancelled");
    }

    private async Task MarkRequestRead(TutorRequest request)
    {
        RequestActionMessage = string.Empty;
        await JS.InvokeVoidAsync("localStorage.setItem", GetReadRequestStorageKey(request), "1");
        OpenRequests.RemoveAll(openRequest => openRequest.Id == request.Id);

        AddActivity(
            "Status gelesen",
            $"Du hast die Antwort von {request.Name} fuer {request.Subject} abgehakt.",
            "neutral");
    }

    private async Task<List<TutorRequest>> FilterReadRequestsAsync(List<TutorRequest> requests)
    {
        var visibleRequests = new List<TutorRequest>();

        foreach (var request in requests)
        {
            if (request.Direction == TutorRequestDirection.Outgoing
                && request.Status is TutorRequestStatus.Accepted or TutorRequestStatus.Declined
                && await IsRequestMarkedReadAsync(request))
            {
                continue;
            }

            visibleRequests.Add(request);
        }

        return visibleRequests;
    }

    private async Task<bool> IsRequestMarkedReadAsync(TutorRequest request)
    {
        var value = await JS.InvokeAsync<string?>("localStorage.getItem", GetReadRequestStorageKey(request));
        return string.Equals(value, "1", StringComparison.Ordinal);
    }

    private string GetReadRequestStorageKey(TutorRequest request)
    {
        var userId = UserSessionService.CurrentUser?.Uid ?? 0;
        return $"{ReadRequestStoragePrefix}-{userId}-{request.RequestId}";
    }

    private async Task UpdateRequestStatusAsync(TutorRequest request, TutorRequestStatus status, string apiStatus)
    {
        RequestActionMessage = string.Empty;

        var result = await TutorRequestService.UpdateRequestStatusAsync(
            request.RequestId,
            apiStatus,
            UserSessionService.AuthToken,
            request.Description,
            request.Subject);

        if (!result.Success)
        {
            if (ShouldUseLocalStatusFallback(request, status, result.Message))
            {
                RequestStatusOverlay.SetStatus(request.RequestId, status, request.Subject);
                result = TutorRequestResult.Sent();
            }
        }

        if (!result.Success)
        {
            RequestActionMessage = result.Message ?? "Die Anfrage konnte nicht aktualisiert werden.";
            return;
        }

        var updatedRequest = request with
        {
            Status = status
        };

        OpenRequests.RemoveAll(openRequest => openRequest.Id == request.Id);

        if (IsVisibleRequestAfterStatusUpdate(updatedRequest))
        {
            OpenRequests.Insert(0, updatedRequest);
        }

        AddActivity(
            GetRequestActivityTitle(updatedRequest),
            GetRequestActivityDetail(updatedRequest),
            GetRequestActivityTone(updatedRequest));
    }

    private static bool IsVisibleRequestAfterStatusUpdate(TutorRequest request)
    {
        return request.Direction == TutorRequestDirection.Outgoing
            && request.Status is TutorRequestStatus.Accepted or TutorRequestStatus.Declined;
    }

    private static bool ShouldUseLocalStatusFallback(TutorRequest request, TutorRequestStatus status, string? message)
    {
        return request.Direction == TutorRequestDirection.Incoming
            && status is TutorRequestStatus.Accepted or TutorRequestStatus.Declined
            && !string.IsNullOrWhiteSpace(message)
            && message.Contains("nicht mit diesem Login", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetRequestActivityTitle(TutorRequest request)
    {
        return request.Status switch
        {
            TutorRequestStatus.Accepted => "Anfrage angenommen",
            TutorRequestStatus.Declined => "Anfrage abgelehnt",
            TutorRequestStatus.Cancelled => "Anfrage zurückgezogen",
            TutorRequestStatus.Read => "Status gelesen",
            _ => "Anfrage aktualisiert"
        };
    }

    private static string GetRequestActivityDetail(TutorRequest request)
    {
        return request.Status switch
        {
            TutorRequestStatus.Accepted when request.Direction == TutorRequestDirection.Incoming =>
                $"Du hast die Anfrage von {request.Name} fuer {request.Subject} angenommen.",
            TutorRequestStatus.Declined when request.Direction == TutorRequestDirection.Incoming =>
                $"Du hast die Anfrage von {request.Name} fuer {request.Subject} abgelehnt.",
            TutorRequestStatus.Cancelled =>
                $"Du hast deine Anfrage an {request.Name} fuer {request.Subject} zurückgezogen.",
            TutorRequestStatus.Read =>
                $"Du hast die Antwort von {request.Name} fuer {request.Subject} abgehakt.",
            TutorRequestStatus.Accepted =>
                $"{request.Name} hat deine Anfrage fuer {request.Subject} angenommen.",
            TutorRequestStatus.Declined =>
                $"{request.Name} hat deine Anfrage fuer {request.Subject} abgelehnt.",
            _ => $"{request.Name} - {request.Subject} fuer {request.PricePerHour} EUR / h."
        };
    }

    private static string GetRequestActivityTone(TutorRequest request)
    {
        return request.Status switch
        {
            TutorRequestStatus.Accepted => "success",
            TutorRequestStatus.Declined or TutorRequestStatus.Cancelled => "warning",
            _ => "neutral"
        };
    }

    private void CompleteRequest(TutorRequest request, bool isAccepted)
    {
        OpenRequests.RemoveAll(openRequest => openRequest.Id == request.Id);

        AddActivity(
            isAccepted ? "Anfrage angenommen" : "Anfrage abgelehnt",
            $"{request.Name} - {request.Subject} für {request.PricePerHour} EUR / h.",
            isAccepted ? "success" : "warning");
    }

    private void AddActivity(string title, string detail, string tone)
    {
        Activities.Insert(0, new DashboardActivity(Guid.NewGuid(), title, detail, DateTime.Now, tone));

        if (Activities.Count > 5)
        {
            Activities.RemoveRange(5, Activities.Count - 5);
        }
    }

    private async Task RefreshFeedAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(14));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                var template = FeedTemplates[FeedIndex % FeedTemplates.Length];
                FeedIndex++;

                await InvokeAsync(() =>
                {
                    AddActivity(template.Title, template.Detail, template.Tone);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshDashboardAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                var refreshedSnapshot = await DashboardData.GetDashboardAsync(cancellationToken);
                var refreshedRequests = await FilterReadRequestsAsync(refreshedSnapshot.OpenRequests.ToList());

                await InvokeAsync(() =>
                {
                    Snapshot = refreshedSnapshot;
                    OpenRequests = refreshedRequests;
                    Activities = refreshedSnapshot.Activities.ToList();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void GoToOffer()
    {
        NavigationManager.NavigateTo("/profil");
    }

    private async Task DeleteTutorOffer()
    {
        if (Snapshot is null)
        {
            return;
        }

        CurrentTutorOffer ??= await GetCurrentTutorOfferAsync();

        if (CurrentTutorOffer is null)
        {
            DeleteOfferMessage = "Das Angebot konnte nicht gefunden werden.";
            IsDeleteConfirmationVisible = false;
            return;
        }

        if (!IsDeleteConfirmationVisible)
        {
            IsDeleteConfirmationVisible = true;
            DeleteOfferMessage = "Klicke erneut auf Löschen, um dein Angebot dauerhaft zu entfernen.";
            return;
        }

        var result = await TutorDirectoryService.DeleteTutorOfferAsync(CurrentTutorOffer, UserSessionService.AuthToken);

        if (!result.Success)
        {
            DeleteOfferMessage = result.Message ?? "Das Angebot konnte nicht gelöscht werden.";
            IsDeleteConfirmationVisible = false;
            return;
        }

        CurrentTutorOffer = null;
        Snapshot = Snapshot with
        {
            HasOffer = false,
            ActiveOffers = 0
        };
        DeleteOfferMessage = "Dein Angebot wurde gelöscht.";
        IsDeleteConfirmationVisible = false;
    }

    private async Task<TutorOffer?> GetCurrentTutorOfferAsync()
    {
        var currentUser = UserSessionService.CurrentUser;

        if (currentUser is null)
        {
            return null;
        }

        var tutorsResult = await TutorDirectoryService.GetTutorsAsync();

        return tutorsResult.Tutors.FirstOrDefault(tutor =>
            tutor.ExpiresOn >= DateOnly.FromDateTime(DateTime.Today)
            && (tutor.OffererUserId == currentUser.Uid
                || string.Equals(tutor.Email, currentUser.Email, StringComparison.OrdinalIgnoreCase)));
    }

    private void ShowPreviousRevenueYear()
    {
        SelectedRevenueYear--;
    }

    private void ShowNextRevenueYear()
    {
        SelectedRevenueYear++;
    }

    public void Dispose()
    {
        FeedCancellation?.Cancel();
        FeedCancellation?.Dispose();
    }
}
