@page "/login"
@inject NavigationManager NavigationManager
@inject UserProfileService UserProfileService
@inject UserSessionService UserSessionService
@inject AuthSessionStorageService AuthSessionStorage
@inject IJSRuntime JS
@inject ILogger<Login> Logger

<PageTitle>Login / Registrieren</PageTitle>

<section class="auth-page page-with-footer-space">
    <div class="auth-shell">
        <div class="auth-header">
            <p class="profile-kicker">CLASS Konto</p>
            <h1>Login / Registrieren</h1>
        </div>

        <div class="auth-mode-switch" role="tablist" aria-label="Login oder Registrierung auswählen">
            <button type="button"
                    class="@(Mode == AuthMode.Login ? "active" : string.Empty)"
                    @onclick="() => SetMode(AuthMode.Login)"
                    role="tab"
                    aria-selected="@(Mode == AuthMode.Login)">
                Login
            </button>
            <button type="button"
                    class="@(Mode == AuthMode.Register ? "active" : string.Empty)"
                    @onclick="() => SetMode(AuthMode.Register)"
                    role="tab"
                    aria-selected="@(Mode == AuthMode.Register)">
                Registrieren
            </button>
        </div>

        @if (Mode == AuthMode.Login)
        {
            <EditForm Model="LoginModel" OnValidSubmit="HandleLoginAsync" class="auth-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="offer-form-field">
                    <label for="login-email">E-Mail</label>
                    <InputText id="login-email" class="offer-form-input" type="email" @bind-Value="LoginModel.Email" />
                    <ValidationMessage For="@(() => LoginModel.Email)" />
                </div>

                <div class="offer-form-field">
                    <label for="login-password">Passwort</label>
                    <InputText id="login-password" class="offer-form-input" type="password" @bind-Value="LoginModel.Password" />
                    <ValidationMessage For="@(() => LoginModel.Password)" />
                </div>

                @if (!string.IsNullOrWhiteSpace(AuthMessage))
                {
                    <p class="auth-message">@AuthMessage</p>
                }

                <button type="submit" class="btn-primary-custom">Einloggen</button>
            </EditForm>
        }
        else
        {
            <div class="registration-progress" aria-label="Registrierungsfortschritt">
                <span>@(RegistrationStep + 1) / @RegistrationSteps.Length</span>
                <div>
                    <i style="width: @RegistrationProgress"></i>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(AuthMessage))
            {
                <p class="auth-message">@AuthMessage</p>
            }

            <EditForm EditContext="RegistrationEditContext" OnSubmit="HandleRegisterSubmitAsync" class="auth-form">
                <DataAnnotationsValidator />

                @if (RegistrationStep == 0)
                {
                    <div class="offer-form-layout">
                        <div class="offer-form-field">
                            <label for="register-first-name">Vorname</label>
                            <InputText id="register-first-name" class="offer-form-input" @bind-Value="RegistrationModel.FirstName" />
                            <ValidationMessage For="@(() => RegistrationModel.FirstName)" />
                        </div>
                        <div class="offer-form-field">
                            <label for="register-last-name">Nachname</label>
                            <InputText id="register-last-name" class="offer-form-input" @bind-Value="RegistrationModel.LastName" />
                            <ValidationMessage For="@(() => RegistrationModel.LastName)" />
                        </div>
                        <div class="offer-form-field offer-form-field-full">
                            <label for="register-email">E-Mail</label>
                            <InputText id="register-email" class="offer-form-input" type="email" @bind-Value="RegistrationModel.Email" />
                            <ValidationMessage For="@(() => RegistrationModel.Email)" />
                        </div>
                        <div class="offer-form-field offer-form-field-full">
                            <label for="register-password">Passwort</label>
                            <InputText id="register-password" class="offer-form-input" type="password" @bind-Value="RegistrationModel.Password" />
                            <ValidationMessage For="@(() => RegistrationModel.Password)" />
                        </div>
                    </div>
                }
                else if (RegistrationStep == 1)
                {
                    <div class="offer-form-layout">
                        <div class="offer-form-field">
                            <label for="register-grade">Klasse</label>
                            <InputText id="register-grade" class="offer-form-input" placeholder="z. B. 3BHIT" @bind-Value="RegistrationModel.Grade" />
                            <ValidationMessage For="@(() => RegistrationModel.Grade)" />
                        </div>
                        <div class="offer-form-field">
                            <label for="register-school-type">Schultyp</label>
                            <InputSelect id="register-school-type" class="offer-form-input" @bind-Value="RegistrationModel.SchoolType">
                                <option value="">Bitte wählen</option>
                                <option>Tagesschule</option>
                                <option>Abendschule</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => RegistrationModel.SchoolType)" />
                        </div>
                        <div class="offer-form-field offer-form-field-full">
                            <label for="register-birth-date">Geburtsdatum</label>
                            <InputDate id="register-birth-date" class="offer-form-input" @bind-Value="RegistrationModel.BirthDate" />
                            <ValidationMessage For="@(() => RegistrationModel.BirthDate)" />
                        </div>
                        <div class="offer-form-field offer-form-field-full">
                            <label for="register-description">Beschreibung</label>
                            <InputTextArea id="register-description" class="offer-form-input offer-form-textarea" @bind-Value="RegistrationModel.Description" />
                            <ValidationMessage For="@(() => RegistrationModel.Description)" />
                        </div>
                    </div>
                }
                else
                {
                    <div class="registration-image-step">
                        <label class="profile-avatar-shell profile-avatar-upload-label registration-avatar-shell @(HasRegistrationProfileImage ? "has-image" : "is-empty")" for="register-image">
                            @if (HasRegistrationProfileImage)
                            {
                                <span class="registration-avatar-crop-frame">
                                    <img src="@RegistrationProfileImagePreviewUrl"
                                         alt="Profilbild Vorschau"
                                         class="registration-avatar-preview"
                                         style="@RegistrationAvatarPreviewStyle" />
                                </span>
                                <span class="profile-avatar-overlay registration-avatar-overlay" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M4.75 19.25h4.1L18.7 9.4a2.9 2.9 0 0 0-4.1-4.1L4.75 15.15v4.1Z" />
                                        <path d="M13.35 6.55l4.1 4.1" />
                                    </svg>
                                </span>
                            }
                            else
                            {
                                <div class="profile-avatar-placeholder" aria-label="Profilbild hochladen">
                                    <span class="profile-avatar-plus" aria-hidden="true">+</span>
                                </div>
                            }
                            <InputFile id="register-image" class="profile-upload-input" OnChange="HandleProfileImageSelectedAsync" accept="image/*" />
                        </label>
                        <div class="profile-upload-controls registration-image-controls">
                            <span class="registration-image-label">Profilbild</span>
                            <p>@(string.IsNullOrWhiteSpace(RegistrationModel.ProfileImageName) ? "Noch kein Bild ausgewählt" : RegistrationModel.ProfileImageName)</p>

                            @if (HasRegistrationProfileImage)
                            {
                                <div class="crop-controls">
                                    <label for="crop-zoom">Zoom</label>
                                    <input id="crop-zoom" class="crop-slider" type="range" min="1" max="3" step="0.1" @bind="ImageZoomInput" @bind:event="oninput" />
                                    <label for="crop-x" class="@GetCropControlLabelClass(CanOffsetImageX)">Horizontal</label>
                                    <input id="crop-x" class="crop-slider" type="range" min="@(-MaxImageOffsetX)" max="@MaxImageOffsetX" step="1" disabled="@(!CanOffsetImageX)" @bind="ImageOffsetX" @bind:event="oninput" />
                                    <label for="crop-y" class="@GetCropControlLabelClass(CanOffsetImageY)">Vertikal</label>
                                    <input id="crop-y" class="crop-slider" type="range" min="@(-MaxImageOffsetY)" max="@MaxImageOffsetY" step="1" disabled="@(!CanOffsetImageY)" @bind="ImageOffsetY" @bind:event="oninput" />
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="auth-actions">
                    @if (RegistrationStep > 0)
                    {
                        <button type="button" class="btn-secondary-custom" @onclick="PreviousRegistrationStep" disabled="@IsRegistering">Zurück</button>
                    }
                    <button type="submit" class="btn-primary-custom" disabled="@IsRegistering">@GetRegisterButtonText()</button>
                </div>
            </EditForm>
        }
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    public string? ReturnUrlQuery { get; set; }

    [Parameter]
    public string? ReturnUrl { get; set; }

    [Parameter]
    public string InitialMode { get; set; } = "login";

    private enum AuthMode
    {
        Login,
        Register
    }

    private static readonly string[] RegistrationSteps = ["Konto", "Schule", "Bild"];

    private const long MaxProfileImageSizeBytes = 5 * 1024 * 1024;

    private LoginFormModel LoginModel { get; set; } = new();

    private RegistrationFormModel RegistrationModel { get; set; } = new();

    private EditContext RegistrationEditContext { get; set; } = default!;

    private ValidationMessageStore RegistrationValidationMessages { get; set; } = default!;

    private AuthMode Mode { get; set; }

    private int RegistrationStep { get; set; }

    private string AuthMessage { get; set; } = string.Empty;

    private bool IsRegistering { get; set; }

    private string RegistrationProfileImagePreviewUrl { get; set; } = string.Empty;

    private string RegistrationProgress => $"{((RegistrationStep + 1) * 100) / RegistrationSteps.Length}%";

    private const int CropOutputSize = 512;

    private double ImageZoom { get; set; } = 1.0;

    private int imageOffsetX;

    private int imageOffsetY;

    private double ImageNaturalWidth { get; set; }

    private double ImageNaturalHeight { get; set; }

    private string ImageZoomInput
    {
        get => ImageZoom.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
        set
        {
            if (double.TryParse(value, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var zoom))
            {
                ImageZoom = Math.Clamp(zoom, 1.0, 3.0);
                ClampImageOffsets();
            }
        }
    }

    private int ImageOffsetX
    {
        get => imageOffsetX;
        set => imageOffsetX = ClampImageOffset(value, MaxImageOffsetX);
    }

    private int ImageOffsetY
    {
        get => imageOffsetY;
        set => imageOffsetY = ClampImageOffset(value, MaxImageOffsetY);
    }

    private int MaxImageOffsetX => GetMaxImageOffset(isHorizontal: true);

    private int MaxImageOffsetY => GetMaxImageOffset(isHorizontal: false);

    private bool CanOffsetImageX => MaxImageOffsetX > 0;

    private bool CanOffsetImageY => MaxImageOffsetY > 0;

    private string RegistrationAvatarPreviewStyle
    {
        get
        {
            var widthPercent = GetPreviewImagePercent(isHorizontal: true);
            var heightPercent = GetPreviewImagePercent(isHorizontal: false);
            var leftPercent = 50 + (ImageOffsetX * 100.0 / CropOutputSize);
            var topPercent = 50 + (ImageOffsetY * 100.0 / CropOutputSize);

            return FormattableString.Invariant(
                $"width: {widthPercent:0.###}%; height: {heightPercent:0.###}%; left: {leftPercent:0.###}%; top: {topPercent:0.###}%;");
        }
    }

    private bool HasRegistrationProfileImage => !string.IsNullOrWhiteSpace(RegistrationProfileImagePreviewUrl);

    protected override void OnParametersSet()
    {
        if (RegistrationEditContext is null)
        {
            RegistrationEditContext = new EditContext(RegistrationModel);
            RegistrationValidationMessages = new ValidationMessageStore(RegistrationEditContext);
        }

        Mode = string.Equals(InitialMode, "register", StringComparison.OrdinalIgnoreCase)
            ? AuthMode.Register
            : AuthMode.Login;
    }

    private void SetMode(AuthMode mode)
    {
        Mode = mode;
        AuthMessage = string.Empty;
    }

    private async Task HandleLoginAsync()
    {
        AuthMessage = string.Empty;
        var result = await UserProfileService.LoginAsync(LoginModel.Email, LoginModel.Password);

        if (result.IsAuthenticated && result.User is not null)
        {
            var authToken = result.AuthToken ?? string.Empty;
            UserSessionService.SignIn(result.User, authToken);
            await AuthSessionStorage.SaveTokenAsync(authToken);
            NavigationManager.NavigateTo(GetReturnUrl(), replace: true);
            return;
        }

        AuthMessage = result.ErrorMessage ?? "Login fehlgeschlagen.";
    }

    private async Task HandleRegisterSubmitAsync(EditContext editContext)
    {
        if (IsRegistering)
        {
            return;
        }

        if (!ValidateRegistrationStep())
        {
            return;
        }

        if (RegistrationStep < RegistrationSteps.Length - 1)
        {
            RegistrationStep++;
            AuthMessage = string.Empty;
            return;
        }

        IsRegistering = true;
        AuthMessage = string.Empty;

        try
        {
            try
            {
                RegistrationModel.CroppedProfileImageDataUrl = await CropProfileImageAsync();
            }
            catch (Exception exception)
            {
                Logger.LogWarning(exception, "Profile image cropping failed during registration.");
                AuthMessage = $"Das Profilbild konnte nicht verarbeitet werden: {exception.Message}";
                return;
            }

            var result = await UserProfileService.RegisterAsync(RegistrationModel);

            if (!result.IsAuthenticated || result.User is null)
            {
                AuthMessage = result.ErrorMessage ?? "Registrierung fehlgeschlagen.";
                return;
            }

            var authToken = result.AuthToken ?? string.Empty;
            UserSessionService.SignIn(result.User, authToken);
            await AuthSessionStorage.SaveTokenAsync(authToken);
            NavigationManager.NavigateTo(GetReturnUrl(), replace: true);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Registration submit failed unexpectedly.");
            AuthMessage = $"Registrierung fehlgeschlagen: {exception.Message}";
        }
        finally
        {
            IsRegistering = false;
        }
    }

    private void PreviousRegistrationStep()
    {
        RegistrationStep = Math.Max(0, RegistrationStep - 1);
        AuthMessage = string.Empty;
    }

    private async Task HandleProfileImageSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;

        if (file.Size > MaxProfileImageSizeBytes)
        {
            RegistrationModel.ProfileImageName = string.Empty;
            RegistrationModel.ProfileImageDataUrl = string.Empty;
            RegistrationProfileImagePreviewUrl = string.Empty;
            AuthMessage = $"Das Bild überschreitet die maximale Größe von {GetMaxProfileImageSizeText()}.";
            return;
        }

        LoadedImageInfo imageInfo;

        try
        {
            imageInfo = await JS.InvokeAsync<LoadedImageInfo>(
                "profileImageCropper.loadFromInput",
                "register-image");
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Profile image could not be loaded for registration.");
            RegistrationModel.ProfileImageName = string.Empty;
            RegistrationModel.ProfileImageDataUrl = string.Empty;
            RegistrationProfileImagePreviewUrl = string.Empty;
            AuthMessage = $"Das Profilbild konnte nicht geladen werden: {exception.Message}";
            return;
        }

        RegistrationModel.ProfileImageName = file.Name;
        RegistrationModel.ProfileImageDataUrl = string.Empty;
        RegistrationProfileImagePreviewUrl = imageInfo.Url;
        ImageNaturalWidth = imageInfo.Width;
        ImageNaturalHeight = imageInfo.Height;
        ImageZoom = 1.0;
        ImageOffsetX = 0;
        ImageOffsetY = 0;
        AuthMessage = string.Empty;
    }

    private string GetRegisterButtonText()
    {
        if (IsRegistering)
        {
            return "Registrierung läuft...";
        }

        return RegistrationStep == RegistrationSteps.Length - 1 ? "Registrierung abschließen" : "Weiter";
    }

    private string GetRegistrationInitials()
    {
        var first = string.IsNullOrWhiteSpace(RegistrationModel.FirstName) ? string.Empty : RegistrationModel.FirstName.Trim()[0].ToString();
        var last = string.IsNullOrWhiteSpace(RegistrationModel.LastName) ? string.Empty : RegistrationModel.LastName.Trim()[0].ToString();
        var initials = $"{first}{last}".ToUpperInvariant();

        return string.IsNullOrWhiteSpace(initials) ? "CL" : initials;
    }

    private bool ValidateRegistrationStep()
    {
        RegistrationValidationMessages.Clear();

        string[] fields = RegistrationStep switch
        {
            0 =>
            [
                nameof(RegistrationFormModel.FirstName),
                nameof(RegistrationFormModel.LastName),
                nameof(RegistrationFormModel.Email),
                nameof(RegistrationFormModel.Password)
            ],
            1 =>
            [
                nameof(RegistrationFormModel.Grade),
                nameof(RegistrationFormModel.SchoolType),
                nameof(RegistrationFormModel.BirthDate),
                nameof(RegistrationFormModel.Description)
            ],
            _ => [nameof(RegistrationFormModel.ProfileImageName)]
        };

        foreach (var field in fields)
        {
            ValidateRegistrationField(field);
        }

        if (RegistrationStep == 2 && string.IsNullOrWhiteSpace(RegistrationModel.ProfileImageName))
        {
            AuthMessage = "Bitte wähle zuerst ein Profilbild aus, damit du dich registrieren kannst.";
            RegistrationValidationMessages.Add(
                RegistrationEditContext.Field(nameof(RegistrationFormModel.ProfileImageName)),
                AuthMessage);
        }

        if (RegistrationStep == 1 && RegistrationModel.BirthDate.HasValue && !IsValidBirthDate(RegistrationModel.BirthDate.Value))
        {
            RegistrationValidationMessages.Add(
                RegistrationEditContext.Field(nameof(RegistrationFormModel.BirthDate)),
                "Ungültiges Datum.");
        }

        RegistrationEditContext.NotifyValidationStateChanged();

        return !fields.Any(field => RegistrationEditContext.GetValidationMessages(RegistrationEditContext.Field(field)).Any());
    }

    private static bool IsValidBirthDate(DateOnly birthDate)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var earliestBirthDate = today.AddYears(-100);

        return birthDate >= earliestBirthDate && birthDate <= today;
    }

    private void ValidateRegistrationField(string fieldName)
    {
        var property = typeof(RegistrationFormModel).GetProperty(fieldName);

        if (property is null)
        {
            return;
        }

        var validationContext = new System.ComponentModel.DataAnnotations.ValidationContext(RegistrationModel)
        {
            MemberName = fieldName
        };
        var results = new List<System.ComponentModel.DataAnnotations.ValidationResult>();

        System.ComponentModel.DataAnnotations.Validator.TryValidateProperty(
            property.GetValue(RegistrationModel),
            validationContext,
            results);

        foreach (var result in results)
        {
            RegistrationValidationMessages.Add(RegistrationEditContext.Field(fieldName), result.ErrorMessage ?? "Ungültige Eingabe.");
        }
    }

    private string GetReturnUrl()
    {
        var returnUrl = string.IsNullOrWhiteSpace(ReturnUrl) ? ReturnUrlQuery : ReturnUrl;

        return string.IsNullOrWhiteSpace(returnUrl) ? "/profil" : returnUrl;
    }

    private static string GetMaxProfileImageSizeText()
    {
        return $"{MaxProfileImageSizeBytes / 1024 / 1024} MB";
    }

    private async Task<string> CropProfileImageAsync()
    {
        if (!HasRegistrationProfileImage)
        {
            return string.Empty;
        }

        return await JS.InvokeAsync<string>(
            "profileImageCropper.cropLoaded",
            "register-image",
            ImageZoom,
            ImageOffsetX,
            ImageOffsetY,
            CropOutputSize);
    }

    private int GetMaxImageOffset(bool isHorizontal)
    {
        var renderedSize = GetRenderedImageSize(isHorizontal);
        var overflow = Math.Max(0, renderedSize - CropOutputSize);

        return (int)Math.Floor(overflow / 2);
    }

    private double GetRenderedImageSize(bool isHorizontal)
    {
        if (ImageNaturalWidth <= 0 || ImageNaturalHeight <= 0)
        {
            return CropOutputSize * ImageZoom;
        }

        var coverScale = Math.Max(CropOutputSize / ImageNaturalWidth, CropOutputSize / ImageNaturalHeight) * ImageZoom;

        return (isHorizontal ? ImageNaturalWidth : ImageNaturalHeight) * coverScale;
    }

    private double GetPreviewImagePercent(bool isHorizontal)
    {
        return GetRenderedImageSize(isHorizontal) * 100 / CropOutputSize;
    }

    private static int ClampImageOffset(int offset, int maxOffset)
    {
        return Math.Clamp(offset, -maxOffset, maxOffset);
    }

    private void ClampImageOffsets()
    {
        imageOffsetX = ClampImageOffset(imageOffsetX, MaxImageOffsetX);
        imageOffsetY = ClampImageOffset(imageOffsetY, MaxImageOffsetY);
    }

    private static string GetCropControlLabelClass(bool isEnabled)
    {
        return isEnabled ? string.Empty : "is-disabled";
    }

    private sealed class LoadedImageInfo
    {
        [System.Text.Json.Serialization.JsonPropertyName("url")]
        public string Url { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("width")]
        public double Width { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("height")]
        public double Height { get; set; }
    }
}
