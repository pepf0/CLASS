@page "/nachhilfe"

<PageTitle>Nachhilfe</PageTitle>

<section class="tutoring-page page-with-footer-space">
    <div class="tutoring-header">
        <h1>Nachhilfeangebote</h1>
        <p>Finde passende Tutorinnen und Tutoren nach Fach, Bewertung, Preis und Gültigkeit.</p>
    </div>

    <section class="tutor-filters" aria-label="Filter für Nachhilfeangebote">
        <div class="filter-field">
            <label for="subject-filter">Fach</label>
            <select id="subject-filter" class="filter-input" @bind="SelectedSubject">
                <option value="">Alle Fächer</option>
                @foreach (var subject in AvailableSubjects)
                {
                    <option value="@subject">@subject</option>
                }
            </select>
        </div>

        <div class="filter-field">
            <label for="price-filter">Max. Preis pro Stunde</label>
            <input id="price-filter"
                   class="filter-input"
                   type="number"
                   min="0"
                   step="1"
                   placeholder="z. B. 15"
                   @bind="MaxPriceInput" />
        </div>

        <div class="filter-field">
            <label for="date-filter">Gültig bis mindestens</label>
            <input id="date-filter" class="filter-input" type="date" @bind="AvailableUntil" />
        </div>

        <div class="filter-field">
            <label>Bewertung</label>
            <div class="filter-stars" role="group" aria-label="Nach Mindestbewertung filtern">
                @for (var i = 1; i <= 5; i++)
                {
                    var starValue = i;
                    var isActive = SelectedMinRating.HasValue && starValue <= SelectedMinRating.Value;
                    var isSelected = SelectedMinRating == starValue;

                    <button type="button"
                            class="filter-star-button @(isSelected ? "selected" : string.Empty)"
                            @onclick="() => ToggleMinRating(starValue)"
                            aria-pressed="@isSelected"
                            aria-label="@($"Mindestens {starValue} Sterne")">
                        <span class="star @(isActive ? "filled" : string.Empty)">
                            @(isActive ? "\u2605" : "\u2606")
                        </span>
                    </button>
                }
            </div>
        </div>

        <div class="filter-actions">
            <div class="filter-field filter-search-field">
                <label for="search-filter">Suche</label>
                <input id="search-filter"
                       class="filter-input"
                       type="text"
                       placeholder="Name, Fach oder Klasse"
                       @bind="SearchTerm"
                       @bind:event="oninput" />
            </div>

            <button type="button" class="filter-reset" @onclick="ResetFilters">Filter zurücksetzen</button>
        </div>
    </section>

    <div class="results-summary">
        <span>@FilteredTutors.Count Angebote</span>
        <span>Sortiert nach Ablaufdatum, Bewertung und Preis</span>
    </div>

    @if (FilteredTutors.Count == 0)
    {
        <div class="empty-state">
            <h3>Keine passenden Angebote gefunden</h3>
            <p>Passe die Filter an oder setze sie zurück.</p>
        </div>
    }
    else
    {
        <div class="tutor-grid">
            @foreach (var tutor in FilteredTutors)
            {
                <article class="tutor-card">
                    <img src="@tutor.ImageUrl" alt="Tutor @tutor.Name" class="tutor-image" />

                    <div class="tutor-content">
                        <div class="tutor-topline">
                            <div>
                                <h3>@tutor.Name</h3>
                                <p class="tutor-school">@tutor.SchoolInfo</p>
                            </div>
                            <span class="expiry-badge">
                                <img src="/images/icons/clock_icon.svg" alt="" class="expiry-icon" aria-hidden="true" />
                                <span>@tutor.ExpiresOn.ToString("dd.MM.yyyy")</span>
                            </span>
                        </div>

                        <div class="tutor-subjects">
                            @foreach (var subject in tutor.Subjects)
                            {
                                <span class="subject-chip">@subject</span>
                            }
                        </div>

                        <div class="tutor-footer">
                            <div class="rating" aria-label="@($"{tutor.Rating} von 5 Sternen")">
                                <span class="stars" aria-hidden="true">
                                    @for (var i = 0; i < 5; i++)
                                    {
                                        if (i < GetFilledStars(tutor.Rating))
                                        {
                                            <span class="star filled">&#9733;</span>
                                        }
                                        else
                                        {
                                            <span class="star">&#9734;</span>
                                        }
                                    }
                                </span>
                                <span class="rating-text">@tutor.Rating.ToString("0.0") (@tutor.ReviewCount)</span>
                            </div>
                            <span class="price">@tutor.PricePerHour EUR / h</span>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private static readonly DateOnly Today = new(2026, 3, 12);

    private readonly List<TutorOffer> Tutors =
    [
        new("Dominik Kautz", "3AHIT, Tagesschule", ["MEDT", "INSY", "Deutsch"], 4.7m, 14, 17, new DateOnly(2026, 5, 29), "/images/tutors/tutor-2.png"),
        new("Noel Hollnthoner", "3AHIT, Tagesschule", ["SEW", "Ethik", "Sport"], 4.5m, 10, 15, new DateOnly(2026, 5, 24), "/images/tutors/tutor-4.png"),
        new("Alisandro Gourie", "3AHIT, Tagesschule", ["SEW", "NWT", "INSY"], 4.8m, 17, 18, new DateOnly(2026, 6, 9), "/images/tutors/tutor-5.png"),
        new("Eljon Bacaj", "3AHIT, Tagesschule", ["SEW", "MEDT", "INSY"], 4.9m, 23, 19, new DateOnly(2026, 5, 18), "/images/tutors/tutor-6.png"),
        new("Bekir Dayi", "3AHIT, Tagesschule", ["Sport"], 4.6m, 11, 16, new DateOnly(2026, 6, 17), "/images/tutors/tutor-7.png"),
    ];

    private string SelectedSubject { get; set; } = string.Empty;

    private string SearchTerm { get; set; } = string.Empty;

    private string MaxPriceInput { get; set; } = string.Empty;

    private int? SelectedMinRating { get; set; }

    private DateOnly? AvailableUntil { get; set; }

    private IEnumerable<string> AvailableSubjects =>
        Tutors.SelectMany(t => t.Subjects)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(subject => subject);

    private List<TutorOffer> FilteredTutors =>
        Tutors.Where(tutor => tutor.ExpiresOn >= Today)
            .Where(tutor => string.IsNullOrWhiteSpace(SearchTerm)
                || tutor.Name.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                || tutor.SchoolInfo.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
                || tutor.Subjects.Any(subject => subject.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)))
            .Where(tutor => string.IsNullOrWhiteSpace(SelectedSubject) || tutor.Subjects.Contains(SelectedSubject, StringComparer.OrdinalIgnoreCase))
            .Where(tutor => !SelectedMinRating.HasValue || tutor.Rating >= SelectedMinRating.Value)
            .Where(tutor => !MaxPrice.HasValue || tutor.PricePerHour <= MaxPrice.Value)
            .Where(tutor => !AvailableUntil.HasValue || tutor.ExpiresOn >= AvailableUntil.Value)
            .OrderBy(GetTutorImageOrder)
            .ToList();

    private int? MaxPrice =>
        int.TryParse(MaxPriceInput, out var value) ? value : null;

    private void ResetFilters()
    {
        SearchTerm = string.Empty;
        SelectedSubject = string.Empty;
        MaxPriceInput = string.Empty;
        SelectedMinRating = null;
        AvailableUntil = null;
    }

    private void ToggleMinRating(int rating)
    {
        SelectedMinRating = SelectedMinRating == rating ? null : rating;
    }

    private static int GetFilledStars(decimal rating)
    {
        var rounded = (int)Math.Round(rating, MidpointRounding.AwayFromZero);
        return Math.Clamp(rounded, 0, 5);
    }

    private static int GetTutorImageOrder(TutorOffer tutor)
    {
        const string marker = "tutor-";
        var imagePath = tutor.ImageUrl;
        var start = imagePath.LastIndexOf(marker, StringComparison.OrdinalIgnoreCase);

        if (start < 0)
        {
            return int.MaxValue;
        }

        start += marker.Length;
        var end = imagePath.IndexOf('.', start);
        var numberText = end >= 0
            ? imagePath[start..end]
            : imagePath[start..];

        return int.TryParse(numberText, out var number) ? number : int.MaxValue;
    }

    private sealed record TutorOffer(
        string Name,
        string SchoolInfo,
        string[] Subjects,
        decimal Rating,
        int ReviewCount,
        int PricePerHour,
        DateOnly ExpiresOn,
        string ImageUrl
    );
}
