@page "/profil"
@inject UserSessionService UserSessionService
@inject NavigationManager NavigationManager

<PageTitle>Profil</PageTitle>

@if (IsLoading)
{
    <section class="profile-page page-with-footer-space">
        <div class="profile-state-card">
            <p class="profile-kicker">Profil</p>
            <h1>Profil wird geladen</h1>
        </div>
    </section>
}
else if (CurrentUser is not null)
{
    <section class="profile-page page-with-footer-space">
        <div class="profile-header">
            <div>
                <p class="profile-kicker">Angemeldet</p>
                <h1>Profil</h1>
                <p class="profile-subtitle">Deine Kontodaten und sichtbaren Profilinformationen.</p>
            </div>
        </div>

        <div class="profile-grid">
            <aside class="profile-card">
                @if (!string.IsNullOrWhiteSpace(UserSessionService.ProfileImageDataUrl))
                {
                    <img src="@UserSessionService.ProfileImageDataUrl" alt="@CurrentUser.FullName" class="profile-avatar" />
                }
                else
                {
                    <div class="profile-avatar-placeholder" aria-label="Profilbild Platzhalter">
                        <span>@GetInitials(CurrentUser)</span>
                    </div>
                }
                <div class="profile-card-content">
                    <h2>@CurrentUser.FullName</h2>
                    <p>@GetSchoolLine(CurrentUser)</p>
                    <a href="mailto:@CurrentUser.Email">@CurrentUser.Email</a>
                    <div class="profile-meta">
                        <span>@CurrentUser.StarRating.ToString("0.0") Sterne</span>
                        <span>@CurrentUser.Rating / 100 Punkte</span>
                    </div>
                </div>
            </aside>

            <section class="profile-detail-panel" aria-labelledby="profile-detail-heading">
                <div class="profile-detail-header">
                    <div>
                        <p class="profile-kicker">Profilinfos</p>
                        <h2 id="profile-detail-heading">Öffentliche Angaben</h2>
                    </div>
                    <span class="profile-id">ID @CurrentUser.Uid</span>
                </div>

                <div class="profile-info-grid">
                    <div class="profile-info-item">
                        <span>Vorname</span>
                        <strong>@CurrentUser.FirstName</strong>
                    </div>
                    <div class="profile-info-item">
                        <span>Nachname</span>
                        <strong>@CurrentUser.LastName</strong>
                    </div>
                    <div class="profile-info-item">
                        <span>Klasse</span>
                        <strong>@GetValueOrPlaceholder(CurrentUser.Grade)</strong>
                    </div>
                    <div class="profile-info-item">
                        <span>Schultyp</span>
                        <strong>@GetValueOrPlaceholder(CurrentUser.SchoolType)</strong>
                    </div>
                    <div class="profile-info-item profile-info-item-wide">
                        <span>Beschreibung</span>
                        <strong>@GetDescription(CurrentUser.Description)</strong>
                    </div>
                    <div class="profile-info-item profile-info-item-wide">
                        <span>Profilbild</span>
                        <strong>@(string.IsNullOrWhiteSpace(UserSessionService.ProfileImageDataUrl) ? "Noch nicht in der Datenbank verfügbar" : "Für diese Sitzung gespeichert")</strong>
                    </div>
                </div>
            </section>
        </div>
    </section>
}
else
{
    <section class="profile-page page-with-footer-space">
        <div class="profile-state-card">
            <p class="profile-kicker">Nicht angemeldet</p>
            <h1>Login erforderlich</h1>
            <p>Bitte melde dich an oder erstelle ein Konto, um dein Profil zu sehen.</p>
            <div class="profile-state-actions">
                <a class="btn-primary-custom" href="/login?returnUrl=/profil">Login / Registrieren</a>
            </div>
        </div>
    </section>
}

@code {
    private bool IsLoading = true;
    private UserProfile? CurrentUser;

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;

        IsLoading = false;
        CurrentUser = UserSessionService.CurrentUser;

        if (CurrentUser is null)
        {
            NavigationManager.NavigateTo("/login?returnUrl=/profil", replace: true);
        }
    }

    private static string GetSchoolLine(UserProfile user)
    {
        var parts = new[] { user.Grade, user.SchoolType }
            .Where(part => !string.IsNullOrWhiteSpace(part))
            .Select(part => part.Trim());

        var value = string.Join(", ", parts);
        return string.IsNullOrWhiteSpace(value) ? "CLASS Profil" : value;
    }

    private static string GetValueOrPlaceholder(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Noch nicht angegeben" : value.Trim();
    }

    private static string GetDescription(string description)
    {
        return string.IsNullOrWhiteSpace(description)
            ? "Noch keine Beschreibung hinterlegt."
            : description.Trim();
    }

    private static string GetInitials(UserProfile user)
    {
        var first = string.IsNullOrWhiteSpace(user.FirstName) ? string.Empty : user.FirstName.Trim()[0].ToString();
        var last = string.IsNullOrWhiteSpace(user.LastName) ? string.Empty : user.LastName.Trim()[0].ToString();
        var initials = $"{first}{last}".ToUpperInvariant();

        return string.IsNullOrWhiteSpace(initials) ? "CL" : initials;
    }
}
