@page "/profil"
@inject UserSessionService UserSessionService
@inject AuthSessionStorageService AuthSessionStorage
@inject UserProfileService UserProfileService
@inject TutorDirectoryService TutorDirectoryService
@inject ProfileImageStorageService ProfileImageStorageService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Profil</PageTitle>

@if (IsLoading)
{
    <section class="profile-page page-with-footer-space">
        <div class="profile-state-card">
            <p class="profile-kicker">Profil</p>
            <h1>Profil wird geladen</h1>
        </div>
    </section>
}
else if (CurrentUser is not null)
{
    <section class="profile-page page-with-footer-space">
        <div class="profile-hero">
            <div class="profile-hero-main">
                <label class="profile-avatar-shell profile-avatar-upload-label @(HasProfileImage ? "has-image" : "is-empty")" for="profile-image-upload">
                    @if (HasProfileImage)
                    {
                        <img src="@UserSessionService.ProfileImageUrl" alt="@CurrentUser.FullName" class="profile-avatar" />
                        <span class="profile-avatar-overlay">Profilbild &auml;ndern</span>
                    }
                    else
                    {
                        <div class="profile-avatar-placeholder" aria-label="Profilbild hochladen">
                            <span class="profile-avatar-plus" aria-hidden="true">+</span>
                        </div>
                    }
                    <InputFile id="profile-image-upload" class="profile-upload-input" OnChange="HandleProfileImageSelectedAsync" accept="image/*" />
                </label>

                <div class="profile-hero-copy">
                    <p class="profile-kicker">Mein Profil</p>
                    <h1>@CurrentUser.FullName</h1>
                    <p class="profile-subtitle">Hier verwaltest du deine Kontodaten, dein sichtbares CLASS Profil und dein Tutor-Angebot.</p>
                    <div class="profile-hero-actions">
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ProfileImageUploadMessage))
        {
            <p class="profile-upload-message">@ProfileImageUploadMessage</p>
        }

        <div class="profile-grid">
            <section class="profile-detail-panel profile-account-panel" aria-labelledby="profile-account-heading">
                <div class="profile-detail-header">
                    <div>
                        <p class="profile-kicker">Accountverwaltung</p>
                        <h2 id="profile-account-heading">Deine Daten</h2>
                    </div>
                </div>

                <EditForm Model="CurrentUser" OnValidSubmit="SaveProfileChanges" class="profile-edit-form">
                    <div class="profile-info-grid">
                        <div class="offer-form-field">
                            <label for="profile-first-name">Vorname</label>
                            <InputText id="profile-first-name" class="offer-form-input" @bind-Value="CurrentUser.FirstName" />
                        </div>
                        <div class="offer-form-field">
                            <label for="profile-last-name">Nachname</label>
                            <InputText id="profile-last-name" class="offer-form-input" @bind-Value="CurrentUser.LastName" />
                        </div>
                        <div class="offer-form-field profile-info-item-wide">
                            <label for="profile-email">E-Mail</label>
                            <InputText id="profile-email" class="offer-form-input" type="email" @bind-Value="CurrentUser.Email" />
                        </div>
                        <div class="offer-form-field">
                            <label for="profile-grade">Klasse</label>
                            <InputText id="profile-grade" class="offer-form-input" placeholder="z. B. 3BHIT" @bind-Value="CurrentUser.Grade" />
                        </div>
                        <div class="offer-form-field">
                            <label for="profile-school-type">Schultyp</label>
                            <InputSelect id="profile-school-type" class="offer-form-input" @bind-Value="CurrentUser.SchoolType">
                                <option value="">Bitte w&auml;hlen</option>
                                <option>Tagesschule</option>
                                <option>Abendschule</option>
                            </InputSelect>
                        </div>
                        <div class="offer-form-field profile-info-item-wide">
                            <label for="profile-description">Beschreibung</label>
                            <InputTextArea id="profile-description" class="offer-form-input offer-form-textarea" @bind-Value="CurrentUser.Description" />
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(ProfileSaveMessage))
                    {
                        <p class="profile-save-message">@ProfileSaveMessage</p>
                    }

                    <div class="profile-edit-actions">
                        <button type="submit" class="btn-primary-custom">Daten speichern</button>
                    </div>
                </EditForm>
            </section>

            <aside class="profile-tutor-panel" aria-labelledby="profile-tutor-heading">
                <div class="profile-detail-header">
                    <div>
                        <p class="profile-kicker">Tutor-Profil</p>
                        <h2 id="profile-tutor-heading">@GetTutorPanelTitle()</h2>
                    </div>

                    @if (CanCreateTutorOffer)
                    {
                        <button type="button"
                                class="tutor-add-button tutor-add-button-small"
                                title="Nachhilfeangebot erstellen"
                                aria-label="Nachhilfeangebot erstellen"
                                @onclick="OpenTutorCreate">
                            <span aria-hidden="true">+</span>
                        </button>
                    }
                    else if (CurrentTutorOffer is not null)
                    {
                        <button type="button"
                                class="btn-danger-custom profile-tutor-delete-button"
                                @onclick="DeleteTutorOffer">
                            @(IsDeleteConfirmationVisible ? "Wirklich löschen?" : "Löschen")
                        </button>
                    }
                </div>

                @if (IsTutorLoading)
                {
                    <p class="profile-tutor-muted">Tutor-Angebot wird geladen.</p>
                }
                else if (CurrentTutorOffer is not null)
                {
                    <div class="profile-tutor-metrics" aria-label="Tutor Kennzahlen">
                        <div>
                            <span>Preis pro Stunde</span>
                            <strong>@GetPriceText(CurrentTutorOffer)</strong>
                        </div>
                        <div>
                            <span>Bewertung</span>
                            <div class="profile-stars" aria-label="@($"{CurrentTutorOffer.Rating:0.0} von 5 Sternen")">
                                @for (var i = 0; i < 5; i++)
                                {
                                    var starClass = GetStarFillClass(CurrentTutorOffer.Rating, i);
                                    var halfGradientId = $"profile-rating-star-{i}-half";
                                    var fill = starClass switch
                                    {
                                        "filled" => "#ffb300",
                                        "half-filled" => $"url(#{halfGradientId})",
                                        _ => "#d6c6a0"
                                    };

                                    <span class="profile-star @starClass" aria-hidden="true">
                                        <svg class="profile-star-svg" viewBox="0 0 24 24" focusable="false">
                                            <defs>
                                                <linearGradient id="@halfGradientId" x1="0%" y1="0%" x2="100%" y2="0%">
                                                    <stop offset="0%" stop-color="#ffb300" />
                                                    <stop offset="50%" stop-color="#ffb300" />
                                                    <stop offset="50%" stop-color="#c8ad72" />
                                                    <stop offset="100%" stop-color="#8f7a51" />
                                                </linearGradient>
                                            </defs>
                                            <path class="profile-star-shape" fill="@fill" d="M12 2.4l2.96 6 6.62.96-4.79 4.67 1.13 6.59L12 17.51l-5.92 3.11 1.13-6.59-4.79-4.67 6.62-.96L12 2.4Z" />
                                            <path class="profile-star-sheen" d="M12 4.5l2.2 4.45 4.9.72-3.55 3.45.84 4.88L12 15.7 7.61 18l.84-4.88L4.9 9.67l4.9-.72L12 4.5Z" />
                                        </svg>
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="profile-tutor-section">
                        <span>Angebotene F&auml;cher</span>
                        <div class="profile-subject-list">
                            @if (CurrentTutorOffer.Subjects.Length == 0)
                            {
                                <span class="subject-chip">F&auml;cher folgen</span>
                            }
                            else
                            {
                                @foreach (var subject in CurrentTutorOffer.Subjects)
                                {
                                    <span class="subject-chip">@subject</span>
                                }
                            }
                        </div>
                    </div>

                    <p class="profile-tutor-description">@CurrentTutorOffer.Description</p>

                    @if (!string.IsNullOrWhiteSpace(TutorDeleteMessage))
                    {
                        <p class="profile-save-message profile-delete-message">@TutorDeleteMessage</p>
                    }
                }
                else
                {
                    <div class="profile-tutor-empty">
                        <strong>Noch kein aktives Tutor-Profil</strong>
                        <p>Als CLASS Nutzer bist du Sch&uuml;ler. Wenn du Nachhilfe anbietest, erscheint hier dein Angebot mit F&auml;chern, Preis und Bewertung.</p>
                        @if (!string.IsNullOrWhiteSpace(TutorLoadMessage))
                        {
                            <small>@TutorLoadMessage</small>
                        }
                    </div>
                }
            </aside>
        </div>

        <TutorOfferCreateModal IsOpen="IsCreatingTutorOffer"
                               IdPrefix="profile-create-offer"
                               OnClosed="CloseTutorCreate"
                               OnCreated="HandleTutorOfferCreated" />
    </section>
}
else
{
    <section class="profile-page page-with-footer-space">
        <div class="profile-state-card">
            <p class="profile-kicker">Nicht angemeldet</p>
            <h1>Login erforderlich</h1>
            <p>Bitte melde dich an oder erstelle ein Konto, um dein Profil zu sehen.</p>
            <div class="profile-state-actions">
                <a class="btn-primary-custom" href="/login?returnUrl=/profil">Login / Registrieren</a>
            </div>
        </div>
    </section>
}

@code {
    private const long MaxProfileImageSizeBytes = 5 * 1024 * 1024;

    private bool IsLoading = true;
    private bool IsTutorLoading;
    private bool IsCreatingTutorOffer;
    private UserProfile? CurrentUser;
    private TutorOffer? CurrentTutorOffer;
    private string ProfileImageUploadMessage { get; set; } = string.Empty;
    private string ProfileSaveMessage { get; set; } = string.Empty;
    private string TutorLoadMessage { get; set; } = string.Empty;
    private string TutorDeleteMessage { get; set; } = string.Empty;
    private bool IsDeleteConfirmationVisible { get; set; }

    private bool HasProfileImage => !string.IsNullOrWhiteSpace(UserSessionService.ProfileImageUrl);

    private DateOnly Today => DateOnly.FromDateTime(DateTime.Today);

    private bool CanCreateTutorOffer =>
        CurrentUser is not null && CurrentTutorOffer is null && !IsTutorLoading;

    protected override async Task OnInitializedAsync()
    {
        CurrentUser = UserSessionService.CurrentUser;

        if (CurrentUser is null)
        {
            await AuthSessionStorage.RestoreFromCookieAsync();
            CurrentUser = UserSessionService.CurrentUser;
        }

        if (CurrentUser is null)
        {
            IsLoading = false;
            NavigationManager.NavigateTo("/login?returnUrl=/profil", replace: true);
            return;
        }

        IsLoading = false;
        IsTutorLoading = true;

        var tutorResult = await TutorDirectoryService.GetTutorsAsync();
        CurrentTutorOffer = tutorResult.Tutors.FirstOrDefault(tutor => IsCurrentUserTutorOffer(tutor) && tutor.ExpiresOn >= Today);
        TutorLoadMessage = IsApiLoadedCountMessage(tutorResult.Message) ? string.Empty : tutorResult.Message ?? string.Empty;
        IsTutorLoading = false;
    }

    private async Task HandleProfileImageSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        ProfileImageUploadMessage = string.Empty;

        if (file.Size > MaxProfileImageSizeBytes)
        {
            ProfileImageUploadMessage = $"Das Bild überschreitet die maximale Größe von {GetMaxProfileImageSizeText()}.";
            return;
        }

        if (CurrentUser is null)
        {
            return;
        }

        try
        {
            await JS.InvokeAsync<LoadedImageInfo>(
                "profileImageCropper.loadFromInput",
                "profile-image-upload");

            var webpDataUrl = await JS.InvokeAsync<string>(
                "profileImageCropper.cropLoaded",
                "profile-image-upload",
                1.0,
                0,
                0,
                512);
            var imageUrl = await ProfileImageStorageService.SaveProfileImageDataUrlAsync(CurrentUser.Uid, webpDataUrl);

            UserSessionService.UpdateProfileImageUrl(imageUrl);
            ProfileImageUploadMessage = $"{file.Name} wurde als WebP-Profilbild gespeichert.";

            if (CurrentTutorOffer is not null)
            {
                CurrentTutorOffer = CurrentTutorOffer with { ImageUrl = imageUrl };
            }
        }
        catch (Exception exception)
        {
            ProfileImageUploadMessage = $"Das Profilbild konnte nicht gespeichert werden: {exception.Message}";
        }
    }

    private async Task SaveProfileChanges()
    {
        if (CurrentUser is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(UserSessionService.AuthToken))
        {
            ProfileSaveMessage = "Deine Daten konnten nicht gespeichert werden, weil du nicht authentifiziert bist.";
            return;
        }

        var wasSaved = await UserProfileService.UpdateProfileAsync(
            CurrentUser.Uid,
            CurrentUser.Description,
            CurrentUser.Grade,
            CurrentUser.SchoolType,
            UserSessionService.AuthToken);

        ProfileSaveMessage = wasSaved
            ? "Deine Daten wurden gespeichert."
            : "Deine Daten konnten nicht gespeichert werden.";
    }

    private bool IsCurrentUserTutorOffer(TutorOffer tutor)
    {
        if (CurrentUser is null)
        {
            return false;
        }

        return string.Equals(tutor.Email, CurrentUser.Email, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsApiLoadedCountMessage(string? message)
    {
        return !string.IsNullOrWhiteSpace(message)
            && message.Contains("Nachhilfeangebote wurden aus der API geladen.", StringComparison.OrdinalIgnoreCase);
    }

    private void OpenTutorCreate()
    {
        TutorDeleteMessage = string.Empty;
        IsDeleteConfirmationVisible = false;
        IsCreatingTutorOffer = true;
    }

    private void CloseTutorCreate()
    {
        IsCreatingTutorOffer = false;
    }

    private void HandleTutorOfferCreated(TutorOffer offer)
    {
        CurrentTutorOffer = offer;
        TutorLoadMessage = string.Empty;
        TutorDeleteMessage = string.Empty;
        IsDeleteConfirmationVisible = false;
        IsCreatingTutorOffer = false;
    }

    private async Task DeleteTutorOffer()
    {
        if (CurrentTutorOffer is null)
        {
            return;
        }

        if (!IsDeleteConfirmationVisible)
        {
            IsDeleteConfirmationVisible = true;
            TutorDeleteMessage = "Klicke erneut auf Löschen, um dein Angebot dauerhaft zu entfernen.";
            return;
        }

        var result = await TutorDirectoryService.DeleteTutorOfferAsync(CurrentTutorOffer, UserSessionService.AuthToken);

        if (!result.Success)
        {
            TutorDeleteMessage = result.Message ?? "Das Angebot konnte nicht gelöscht werden.";
            IsDeleteConfirmationVisible = false;
            return;
        }

        CurrentTutorOffer = null;
        TutorDeleteMessage = string.Empty;
        IsDeleteConfirmationVisible = false;
    }

    private string GetTutorPanelTitle()
    {
        return CurrentTutorOffer is null ? "Dein Nachhilfeangebot" : "Dein Angebot";
    }

    private static string GetPriceText(TutorOffer tutor)
    {
        return tutor.PricePerHour <= 0 ? "Preis folgt" : $"{tutor.PricePerHour} EUR / h";
    }

    private static string GetStarFillClass(decimal rating, int starIndex)
    {
        var starPosition = starIndex + 1;

        if (rating >= starPosition)
        {
            return "filled";
        }

        if (rating >= starPosition - 0.5m)
        {
            return "half-filled";
        }

        return "empty";
    }

    private static string GetMaxProfileImageSizeText()
    {
        return $"{MaxProfileImageSizeBytes / 1024 / 1024} MB";
    }

    private sealed class LoadedImageInfo
    {
        [System.Text.Json.Serialization.JsonPropertyName("url")]
        public string Url { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("width")]
        public double Width { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("height")]
        public double Height { get; set; }
    }

}
